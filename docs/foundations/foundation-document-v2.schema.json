{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/foundation-document-v2.schema.json",
  "title": "Sustainable Catalyst Foundation Document",
  "type": "object",
  "required": ["document_id", "title", "record_type", "authority_level", "status", "version", "canonical_record"],
  "properties": {
    "document_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{2,39}$"},
    "title": {"type": "string", "minLength": 1},
    "subtitle": {"type": "string"},
    "record_type": {"enum": ["institutional-standard", "policy-legal-record", "product-system-brief"]},
    "authority_level": {"enum": ["institutional", "methodology", "policy", "product", "historical"]},
    "status": {"enum": ["draft", "under-review", "current-approved-record", "current-living-document", "fixed-approved-snapshot", "superseded", "withdrawn", "historical-record"]},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$"},
    "effective_date": {"type": ["string", "null"], "format": "date"},
    "last_reviewed": {"type": ["string", "null"], "format": "date"},
    "review_cycle": {"type": "string"},
    "owner": {"type": "string"},
    "canonical_record": {"enum": ["living-html", "fixed-pdf", "repository", "historical"]},
    "supersedes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "superseded_by": {"type": ["string", "null"]},
    "related_products": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "related_repositories": {"type": "array", "items": {"type": "string", "format": "uri"}, "uniqueItems": true},
    "correction_url": {"type": ["string", "null"], "format": "uri"},
    "revision_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "date", "status", "summary"],
        "properties": {
          "version": {"type": "string"},
          "date": {"type": "string", "format": "date"},
          "status": {"type": "string"},
          "summary": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
